{
  "name": "harmoneasy",
  "private": true,
  "type": "module",
  "version": "0.15.1",
  "description": "A web-based music collaboration platform that transforms, quantizes, and harmonizes live MIDI input in real-time",
  "author": "designerzen <radio@awesomething.co.uk>",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "postinstall": "git submodule update --remote --init",
    "upgrade:git": "git submodule update --remote",
    "upgrade:npm": "turbo run upgrader",
    "start": "pnpm run dev --filter=harmoneasy",
    "turbo": "turbo",
    "dev": "turbo run dev",
	
    "build:netronome": "pnpm run build --filter=netronome",
    "build": "turbo run build --continue",
    "build:electron": "pnpm --filter ./app/harmoneasy run build:electron",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "upgrader": "pnpm run upgrade:git && pnpm run upgrade:npm",
    "preview": "turbo run preview",
    "clean": "turbo clean && rm -rf .turbo node_modules",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "turbo": "^2.8.14",
    "typescript": "~5.9.3"
  }
}
